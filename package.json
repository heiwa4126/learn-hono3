{
	"name": "hono3",
	"version": "",
	"scripts": {
		"dev": "bun run --hot src/index.ts",
		"preinstall": "bun audit",
		"format": "oxfmt",
		"lint": "oxlint",
		"check": "oxfmt && oxlint --fix",
		"build": "bun build ./src/index.ts --minify --outfile ./dist/hono3.js",
		"start": "bun run ./dist/hono3.js",
		"compile": "bun build --compile ./src/index.ts --outfile ./dist/hono3",
		"ex8": "curl -X POST -H \"Content-Type: application/x-www-form-urlencoded\" -d \"title=hello&body=goodbye\" localhost:3000/rpc/posts"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"hono": "^4.12.9"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11"
	}
}
